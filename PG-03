// Plot Graphs on Auto mpg dataset

import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

df = pd.read_csv(r"C:\Users\hp\Downloads\mpg_raw.csv")

print(df.shape)
print(df.info())
print(df.describe())

print(df.isnull().sum())

df.dropna(inplace=True)
print(df.isnull().sum())

plt.figure(figsize=(8,5))
sns.histplot(df["mpg"], bins=20, kde=True)
plt.title("Histogram of MPG")
plt.show()

plt.figure(figsize=(8,5))
sns.histplot(df["horsepower"], bins=20, kde=True)
plt.title("Histogram of Horsepower")
plt.show()

plt.figure(figsize=(8,5))
sns.scatterplot(data=df, x="weight", y="mpg")
plt.title("Scatter Plot: MPG vs WEIGHT")
plt.show()

plt.figure(figsize=(8,5))
sns.countplot(data=df, x="cylinders")
plt.title("Count Plot of Cylinders")
plt.show()

plt.figure(figsize=(8,5))
sns.pointplot(data=df, x="cylinders", y="mpg")
plt.title("Point Plot: MPG vs Cylinders")
plt.show()
